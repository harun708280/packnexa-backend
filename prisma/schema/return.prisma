model ReturnOrder {
  id                String          @id @default(uuid())
  orderId           String          @unique
  merchantDetailsId String
  status            ReturnStatus    @default(PENDING)
  reason            String?
  adminFeedback     String?
  backToStock       Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order             Order           @relation(fields: [orderId], references: [id])
  merchantDetails   MerchantDetails @relation(fields: [merchantDetailsId], references: [id])
  items             ReturnItem[]
  images            ReturnImage[]

  @@index([merchantDetailsId])
  @@index([status])
  @@map("return_orders")
}

model ReturnItem {
  id            String         @id @default(uuid())
  returnOrderId String
  variantId     String
  quantity      Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  returnOrder   ReturnOrder    @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@map("return_items")
}

model ReturnImage {
  id            String      @id @default(uuid())
  returnOrderId String
  imageUrl      String
  createdAt     DateTime    @default(now())

  returnOrder   ReturnOrder @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)

  @@map("return_images")
}
